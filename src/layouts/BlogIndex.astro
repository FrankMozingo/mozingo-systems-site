---
import Base from "./Base.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;
---

<Base
  canonicalPath="/blog"
  description="Practical guides on AI, automation, data operations, and running a tighter business."
  pageClass="blog-index-page"
  title="Blog"
>
  <section class="blog-index-shell">
    <header class="blog-index-header">
      <span class="blog-index-eyebrow">
        Blog
      </span>
      <h1 class="blog-index-title">
        Practical guidance for operators.
      </h1>
      <p class="blog-index-copy">
        Practical guides on data, automation, and AI - written for business operators, not software teams.
      </p>
    </header>

    {posts.length > 0 ? (
      <div class="blog-index-grid">
        {posts.map((post) => (
          <article class="blog-index-card">
            <a href={`/blog/${post.id}`} class="blog-index-card-link">
              <h2 class="blog-index-card-title">
                {post.data.title}
              </h2>
              <p class="blog-index-card-copy">
                {post.data.description}
              </p>
              <div class="blog-index-card-meta">
                <span class="blog-index-card-date">
                  {new Date(post.data.pubDate).toLocaleDateString("en-US", {
                    day: "numeric",
                    month: "long",
                    year: "numeric",
                  })}
                </span>
                {post.data.youtubeId && (
                  <span class="blog-index-card-flag">
                    Video included
                  </span>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
    ) : (
      <div class="blog-index-empty">
        <h2>The blog infrastructure is live.</h2>
        <p>
          Published posts will appear here once the first article is ready.
        </p>
      </div>
    )}
  </section>
</Base>

---
import Footer from "../components/Footer.astro";
import NavBar from "../components/NavBar.astro";

interface Props {
  canonicalPath?: string;
  description: string;
  ogImage?: string;
  ogImageAlt?: string;
  pageClass?: string;
  schema?: Record<string, unknown>;
  title: string;
}

const {
  canonicalPath = Astro.url.pathname,
  description,
  ogImage = "/assets/Logo.png",
  ogImageAlt = "Mozingo Systems logo",
  pageClass = "",
  schema,
  title,
} = Astro.props;

const siteOrigin = Astro.site?.toString() ?? "https://mozingosystems.com";
const fullTitle = title.includes("Mozingo Systems") ? title : `${title} | Mozingo Systems`;
const canonicalUrl = canonicalPath === "/" ? siteOrigin.replace(/\/$/, "") : new URL(canonicalPath, siteOrigin).toString();
const ogImageUrl = new URL(ogImage, siteOrigin).toString();
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="author" content="Frank Mozingo" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#2f2e2c" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/assets/Logo.png" type="image/png" />
    <meta property="og:site_name" content="Mozingo Systems" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="en_US" />
    <meta name="twitter:card" content="summary" />
    <title>{fullTitle}</title>
    <link rel="stylesheet" href="/styles.css" />
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </head>
  <body class={pageClass}>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <NavBar currentPath={currentPath} />
    <main id="main-content">
      <slot />
    </main>
    <Footer currentPath={currentPath} />
  </body>
</html>

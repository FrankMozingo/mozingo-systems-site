---
import Base from "../layouts/Base.astro";
import siteContent from "../data/site-content";

const { brand, homepage } = siteContent;
const schema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: brand.company,
  url: `${brand.website}/`,
  logo: `${brand.website}/assets/Logo.png`,
  email: brand.contact,
  founder: {
    "@type": "Person",
    name: brand.owner,
  },
  address: {
    "@type": "PostalAddress",
    addressLocality: "Wendell",
    addressRegion: "NC",
    addressCountry: "US",
  },
};
---

<Base
  canonicalPath="/"
  description="Choose a targeted AI product or start an operations improvement audit to find the right path forward."
  pageClass="home-page"
  schema={schema}
  title="AI Products and Operations Improvement"
>
  <section class="home-hero">
    <div class="container home-hero-inner">
      <p class="home-pill"><span class="home-pill-icon" aria-hidden="true"></span> {homepage.preheadline}</p>
      <h1 class="home-title">
        Don't get left behind<br />in the <span>AI era</span>.
      </h1>
      <p class="home-subtitle">{homepage.subhead}</p>

      <div class="home-split-grid" aria-label="Primary paths">
        <article class="home-card home-card-primary">
          <div class="home-card-top">
            <span class="home-card-badge">I know what I want</span>
            <span class="home-card-icon" aria-hidden="true"></span>
          </div>
          <h2>{siteContent.positioning.primaryOffers[0]}</h2>
          <p class="home-card-sub">Targeted solutions, ready to deploy</p>
          <p class="home-card-copy">
            Pick the tool that solves a specific job. No lengthy engagement. Just a narrow, practical
            product that works.
          </p>
          <ul class="home-feature-list">
            {siteContent.aiProducts.offers.map((offer) => <li>{offer.name}</li>)}
          </ul>
          <a class="home-card-cta" href={homepage.primaryCtas[0].href}>{homepage.primaryCtas[0].label}</a>
        </article>

        <article class="home-card home-card-secondary">
          <div class="home-card-top">
            <span class="home-card-badge home-card-badge-secondary">I need help figuring it out</span>
            <span class="home-card-icon home-card-icon-secondary" aria-hidden="true"></span>
          </div>
          <h2>{siteContent.positioning.primaryOffers[1]}</h2>
          <p class="home-card-sub">Find the bottlenecks, then fix them</p>
          <p class="home-card-copy">
            Not sure where to start? We audit how your business actually runs, find hidden costs, data
            friction, and weak handoffs, then plan and implement the right fixes.
          </p>
          <ul class="home-feature-list home-feature-list-secondary">
            <li>Operations audit &amp; planning</li>
            <li>Data cleanup &amp; reporting</li>
            <li>Ongoing maintenance</li>
          </ul>
          <a class="home-card-cta home-card-cta-secondary" href={homepage.primaryCtas[1].href}>
            {homepage.primaryCtas[1].label}
          </a>
        </article>
      </div>
    </div>
  </section>

  <section class="home-trust">
    <div class="container">
      <ul class="home-trust-list" aria-label="Trust signals">
        {homepage.trustSignals.map((signal) => (
          <li><span class="home-trust-icon" aria-hidden="true"></span> {signal}</li>
        ))}
      </ul>
      <ul class="home-industry-list" aria-label={homepage.industryTags.label}>
        <li class="home-industry-label">{homepage.industryTags.label}</li>
        {homepage.industryTags.tags.map((tag) => <li>{tag}</li>)}
      </ul>
    </div>
  </section>

  <section class="home-section home-proof-section">
    <div class="container">
      <div class="home-section-head">
        <p class="home-kicker">{homepage.beforeAfter.title}</p>
        <h2>One missed call is often one lost customer.</h2>
      </div>
      <div class="home-proof-grid">
        <article class="home-proof-card">
          <span class="home-proof-label">Before</span>
          <p>{homepage.beforeAfter.before}</p>
        </article>
        <article class="home-proof-card home-proof-card-accent">
          <span class="home-proof-label">After</span>
          <p>{homepage.beforeAfter.after}</p>
        </article>
      </div>
    </div>
  </section>

  <section class="home-section">
    <div class="container">
      <div class="home-section-head">
        <p class="home-kicker">Why it matters now</p>
        <h2>Small businesses that move first get the easiest wins.</h2>
      </div>
      <div class="home-stats-grid">
        {homepage.whyNow.map((item, index) => (
          <article class="home-stat-card">
            <span class="home-stat-label">{item}</span>
            <p>
              {index === 0 && "Capture calls, leads, and booking requests before they slip away."}
              {index === 1 && "Reduce scheduling, routing, and follow-up overhead every week."}
              {index === 2 && "Use the product route when the job is narrow, or the audit route when the fix is unclear."}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="home-section home-section-divider">
    <div class="container">
      <div class="home-section-head">
        <p class="home-kicker">How the product path works</p>
        <h2>Four steps. No bloated timeline.</h2>
      </div>
      <div class="home-steps-grid">
        {homepage.productPath.map((step, index) => (
          <article class="home-step-card">
            <div
              class={`home-step-track ${
                index === 0
                  ? "home-step-track-full"
                  : index === 1
                    ? "home-step-track-mid"
                    : index === 2
                      ? "home-step-track-low"
                      : "home-step-track-lowest"
              }`}
              aria-hidden="true"
            ></div>
            <span class="home-step-number">{String(index + 1).padStart(2, "0")}</span>
            <h3>{step}</h3>
            <p>
              {index === 0 && "Pick the narrow problem the product must solve: calls, leads, or bookings."}
              {index === 1 && "We wire the product to your existing systems: calendar, CRM, or phone line."}
              {index === 2 && "Most products are running in days, not months."}
              {index === 3 && "We keep it documented, stable, and tuned after launch."}
            </p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="home-about-strip">
    <div class="container home-about-inner">
      <div class="home-avatar" aria-hidden="true">FM</div>
      <div class="home-about-copy">
        <p class="home-about-title">Frank Mozingo - founder</p>
        <p>{homepage.founderStrip}</p>
        <span class="home-veteran-badge"><span aria-hidden="true">◈</span> Veteran-owned &amp; operated</span>
      </div>
    </div>
  </section>

  <section class="home-section home-testimonial-section">
    <div class="container">
      <div class="home-section-head">
        <p class="home-kicker">{homepage.testimonial.title}</p>
        <h2>Professional, knowledgeable, and helpful.</h2>
      </div>
      <blockquote class="home-testimonial">
        <p>"{homepage.testimonial.quote}"</p>
        <cite>{homepage.testimonial.attribution}</cite>
      </blockquote>
    </div>
  </section>

  <section class="home-cta-section">
    <div class="container home-cta-inner">
      <h2>{homepage.closingCta.headline}</h2>
      <p>{homepage.closingCta.copy}</p>
      <div class="home-cta-actions">
        <a class="btn btn-primary home-cta-primary" href={homepage.closingCta.primaryHref}>
          {homepage.closingCta.primaryLabel}
        </a>
        <a class="btn btn-secondary home-cta-secondary" href={homepage.closingCta.secondaryHref}>
          {homepage.closingCta.secondaryLabel}
        </a>
      </div>
    </div>
  </section>
</Base>

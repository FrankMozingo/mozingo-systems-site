---
import Base from "../layouts/Base.astro";
---

<Base canonicalPath="/404" description="The page you requested could not be found." title="Page not found">
  <section class="page-hero">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>Page not found.</h1>
      <p class="page-lead">The route may have changed. Use one of the main paths below to continue.</p>
      <div class="page-actions">
        <a class="btn btn-primary" href="/">Go home</a>
        <a class="btn btn-secondary" href="/contact">Start a conversation</a>
      </div>
    </div>
  </section>
</Base>

---
interface Props {
  title: string;
  videoId: string;
}

const { title, videoId } = Astro.props;
---

<div class="yt-wrapper">
  <iframe
    src={`https://www.youtube.com/embed/${videoId}`}
    title={title}
    frameborder="0"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
    allowfullscreen
    loading="lazy"
  ></iframe>
</div>

---
import { getCollection } from "astro:content";
import siteContent from "../data/site-content";

interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const publishedPosts = await getCollection("blog", ({ data }) => !data.draft);
const navLinks = [...siteContent.navigation];

if (publishedPosts.length > 0) {
  navLinks.splice(2, 0, { label: "Blog", href: "/blog" });
}

function isCurrent(href: string) {
  return currentPath === href || (href !== "/" && currentPath.startsWith(`${href}/`));
}
---

<header class={`site-header${currentPath === "/" ? " home-header" : ""}`}>
  <div class={`container header-inner${currentPath === "/" ? " home-header-inner" : ""}`}>
    <a class={`brand${currentPath === "/" ? " brand-home" : ""}`} href="/" aria-label="Mozingo Systems home">
      <img class="brand-logo" src="/assets/Logo.png" alt="" aria-hidden="true" />
      <span>Mozingo Systems</span>
    </a>
    <nav class={`site-nav${currentPath === "/" ? " home-nav" : ""}`} aria-label="Primary navigation">
      {navLinks.map((link) => (
        <a aria-current={isCurrent(link.href) ? "page" : undefined} href={link.href}>
          {link.label}
        </a>
      ))}
      <a
        aria-current={currentPath === "/contact" ? "page" : undefined}
        class={`nav-cta${currentPath === "/" ? " home-nav-cta" : ""}`}
        href="/contact"
      >
        Start a conversation
      </a>
    </nav>
  </div>
</header>
